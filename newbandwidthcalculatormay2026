            </p>
          </div>
        </div>
      </div>

      {/* Body */}
      <div style={{ maxWidth: 960, margin: "0 auto", padding: "20px 32px 40px" }}>
        <Tabs tabs={tabs} active={tab} onChange={setTab} />

        <div style={cardStyle}>
          {tab === "is" && <ImpactScoreCalc onResult={setIsResult} />}
          {tab === "dcci" && <DCCICalc onResult={setDcciResult} />}
          {tab === "agg" && <AggregateView isResult={isResult} dcciResult={dcciResult} />}
        </div>

        {/* Legend */}
        <div style={{ display: "flex", gap: "16px", flexWrap: "wrap", justifyContent: "center", padding: "12px 0" }}>
          {[
            { c: "#22c55e", l: "Low / Adequate (≤1.0)" },
            { c: "#eab308", l: "Moderate / Watch (1.0–2.5)" },
            { c: "#f97316", l: "Elevated / Constrained (2.5–4.0)" },
            { c: "#ef4444", l: "Critical (>4.0)" },
          ].map((i) => (
            <div key={i.l} style={{ display: "flex", alignItems: "center", gap: "6px", fontSize: "11px", color: VAR.textMuted }}>
              <span style={{ width: 10, height: 10, borderRadius: "3px", background: i.c }} />
              {i.l}
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
