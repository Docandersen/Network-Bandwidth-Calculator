import { useState, useCallback, useEffect } from "react";

// ─── Helpers ───
const fmt = (n, d = 2) => (isNaN(n) || !isFinite(n) ? "—" : n.toFixed(d));
const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));
const lerp = (a, b, t) => a + (b - a) * t;

const severity = (v) => {
  if (v <= 1) return { label: "Low", color: "#22c55e", bg: "rgba(34,197,94,.12)" };
  if (v <= 2.5) return { label: "Moderate", color: "#eab308", bg: "rgba(234,179,8,.12)" };
  if (v <= 4) return { label: "Elevated", color: "#f97316", bg: "rgba(249,115,22,.12)" };
  return { label: "Critical", color: "#ef4444", bg: "rgba(239,68,68,.12)" };
};

const dcciSeverity = (v) => {
  if (v <= 1) return { label: "Adequate", color: "#22c55e", bg: "rgba(34,197,94,.12)" };
  if (v <= 2.5) return { label: "Watch", color: "#eab308", bg: "rgba(234,179,8,.12)" };
  if (v <= 5) return { label: "Constrained", color: "#f97316", bg: "rgba(249,115,22,.12)" };
  return { label: "Critical", color: "#ef4444", bg: "rgba(239,68,68,.12)" };
};

