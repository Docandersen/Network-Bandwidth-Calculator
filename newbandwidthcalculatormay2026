// ─── Input Field ───
function Field({ label, help, value, onChange, min = 0, max, step = 1, unit }) {
  return (
    <div style={{ marginBottom: "14px" }}>
      <label style={labelStyle}>
        {label} {unit && <span style={{ color: VAR.textMuted, fontWeight: 400 }}>({unit})</span>}
      </label>
      <input
        type="number"
        style={inputStyle}
        value={value}
        onChange={(e) => onChange(parseFloat(e.target.value) || 0)}
        min={min}
        max={max}
        step={step}
        onFocus={(e) => (e.target.style.borderColor = VAR.accent)}
        onBlur={(e) => (e.target.style.borderColor = VAR.border)}
      />
      {help && <div style={helpStyle}>{help}</div>}
    </div>
  );
}

// ─── Gauge ───
function Gauge({ value, maxVal, sev, size = 160 }) {
  const pct = clamp(value / maxVal, 0, 1);
  const angle = pct * 240;
  const r = size / 2 - 16;
  const cx = size / 2,
    cy = size / 2 + 10;
  const startAngle = -210;
  const toRad = (deg) => (deg * Math.PI) / 180;
  const arcPoint = (a) => ({
    x: cx + r * Math.cos(toRad(a)),
    y: cy + r * Math.sin(toRad(a)),
  });
  const start = arcPoint(startAngle);
  const end = arcPoint(startAngle + angle);
  const largeArc = angle > 180 ? 1 : 0;
  const bgEnd = arcPoint(startAngle + 240);

  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
      <path
        d={`M ${start.x} ${start.y} A ${r} ${r} 0 1 1 ${bgEnd.x} ${bgEnd.y}`}
        fill="none"
        stroke={VAR.border}
        strokeWidth="10"
        strokeLinecap="round"
      />
      {angle > 0 && (
        <path
          d={`M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArc} 1 ${end.x} ${end.y}`}
          fill="none"
          stroke={sev.color}
          strokeWidth="10"
          strokeLinecap="round"
        />
      )}
      <text
        x={cx}
        y={cy - 8}
        textAnchor="middle"
        fill={sev.color}
        fontFamily={VAR.mono}
        fontSize="28"
        fontWeight="700"
      >
        {fmt(value)}
      </text>
      <text
        x={cx}
        y={cy + 16}
        textAnchor="middle"
        fill={VAR.textDim}
        fontFamily={VAR.font}
        fontSize="12"
        fontWeight="600"
        letterSpacing=".08em"
      >
        {sev.label.toUpperCase()}
      </text>
    </svg>
  );
}

// ─── Radar Chart for Aggregate ───
function RadarChart({ data, size = 280 }) {
  const cx = size / 2, cy = size / 2;
  const r = size / 2 - 40;
  const n = data.length;
  const angleStep = (2 * Math.PI) / n;
  const levels = [0.25, 0.5, 0.75, 1];

  const point = (i, pct) => ({
    x: cx + r * pct * Math.sin(i * angleStep),
    y: cy - r * pct * Math.cos(i * angleStep),
  });

  const dataPath = data
    .map((d, i) => {
      const p = point(i, clamp(d.norm, 0, 1));
      return `${i === 0 ? "M" : "L"} ${p.x} ${p.y}`;
    })
    .join(" ") + " Z";

  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
      {levels.map((l) => (
        <polygon
          key={l}
          points={data.map((_, i) => { const p = point(i, l); return `${p.x},${p.y}`; }).join(" ")}
          fill="none"
          stroke={VAR.border}
          strokeWidth="1"
        />
      ))}
      {data.map((_, i) => {
        const p = point(i, 1);
        return <line key={i} x1={cx} y1={cy} x2={p.x} y2={p.y} stroke={VAR.border} strokeWidth="1" />;
      })}
      <polygon points={data.map((d, i) => { const p = point(i, clamp(d.norm, 0, 1)); return `${p.x},${p.y}`; }).join(" ")} fill="rgba(45,212,191,.18)" stroke={VAR.accent} strokeWidth="2" />
      {data.map((d, i) => {
        const p = point(i, 1.18);
        return (
          <text key={i} x={p.x} y={p.y} textAnchor="middle" dominantBaseline="central" fill={VAR.textDim} fontFamily={VAR.font} fontSize="10" fontWeight="600">
            {d.label}
          </text>
        );
      })}
    </svg>
  );
}

