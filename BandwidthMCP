@mcp.tool(
    name="bw_add_connector",
    annotations={
        "title": "Add Network Source Connector",
        "readOnlyHint": False,
        "destructiveHint": False,
        "idempotentHint": True,
        "openWorldHint": True,
    }
)
async def bw_add_connector(params: ConnectorConfig) -> str:
    """Register a new network device or management platform connector.

    Adds a router, switch, SD-WAN controller, AIOps platform, or NMS to the
    bandwidth calculator's source registry. Registered connectors are polled
    during bandwidth collection and calculation operations.

    Supported connector_type values:
        snmp, netconf, gnmi, rest_api, meraki, viptela, velocloud,
        thousandeyes, solarwinds, dynatrace, prtg, bigpanda, moogsoft

    Args:
        params (ConnectorConfig): Connector configuration including host,
            credentials, site/region tagging, and polling interval.

    Returns:
        str: Confirmation message with connector summary.
    """
    data = params.model_dump()
    _connector_registry[params.connector_id] = data
    _device_registry[params.connector_id] = {
        "id": params.connector_id,
        "hostname": params.host,
        "name": params.name,
        "site": params.site,
        "region": params.region,
    }
    return (
        f"✅ Connector registered successfully.\n\n"
        f"**ID**: `{params.connector_id}`\n"
        f"**Type**: {params.connector_type.value}\n"
        f"**Host**: {params.host}\n"
        f"**Site**: {params.site} | **Region**: {params.region}\n"
        f"**Poll Interval**: {params.poll_interval_seconds}s\n"
        f"**Status**: {'Enabled' if params.enabled else 'Disabled'}\n\n"
        f"Total registered connectors: {len(_connector_registry)}"
    )


@mcp.tool(
    name="bw_list_connectors",
    annotations={
        "title": "List Connected Sources",
        "readOnlyHint": True,
        "destructiveHint": False,
        "idempotentHint": True,
        "openWorldHint": False,
    }
)
async def bw_list_connectors(
    filter_type: Optional[str] = None,
    filter_site: Optional[str] = None,
    filter_region: Optional[str] = None,
    response_format: str = "markdown",
) -> str:
    """List all registered source connectors and their health/status.

    Returns the full inventory of integrated data sources including routers,
    SD-WAN controllers, and AIOps platforms with their connectivity status.

    Args:
        filter_type (str, optional): Filter by connector type (e.g., 'snmp', 'meraki')
        filter_site (str, optional): Filter by site name
        filter_region (str, optional): Filter by region
        response_format (str): 'markdown' or 'json'

    Returns:
        str: Connector inventory with status indicators.
    """
    connectors = list(_connector_registry.values())
    if filter_type:
        connectors = [c for c in connectors if c.get("connector_type") == filter_type]
    if filter_site:
        connectors = [c for c in connectors if c.get("site") == filter_site]
    if filter_region:
        connectors = [c for c in connectors if c.get("region") == filter_region]

    if response_format == "json":
        # Mask passwords in output
        safe = []
        for c in connectors:
            sc = dict(c)
            if "password" in sc:
                sc["password"] = "***"
            safe.append(sc)
        return json.dumps({"count": len(safe), "connectors": safe}, indent=2)

    if not connectors:
        return "No connectors registered. Use `bw_add_connector` to add data sources."

    # Group by connector type
    by_type: Dict[str, List] = {}
    for c in connectors:
        t = c.get("connector_type", "unknown")
        by_type.setdefault(t, []).append(c)

    lines = [f"# Connected Sources ({len(connectors)} total)\n"]
    for ctype, items in sorted(by_type.items()):
        lines.append(f"\n## {ctype.upper()} Connectors ({len(items)})\n")
        lines.append("| ID | Name | Host | Site | Region | Status |")
        lines.append("|---|---|---|---|---|---|")
        for c in items:
            status = "✅ Enabled" if c.get("enabled", True) else "❌ Disabled"
            lines.append(
                f"| `{c['connector_id']}` | {c['name']} | {c['host']} "
                f"| {c.get('site','?')} | {c.get('region','?')} | {status} |"
            )

    # Summary counts
    types_summary = ", ".join(f"{t}: {len(v)}" for t, v in sorted(by_type.items()))
    lines.append(f"\n---\n**Summary**: {types_summary}")
    return "\n".join(lines)


@mcp.tool(
    name="bw_get_device_bandwidth",
    annotations={
        "title": "Get Device Bandwidth Utilization",
        "readOnlyHint": True,
        "destructiveHint": False,
        "idempotentHint": True,
        "openWorldHint": True,
    }
)
async def bw_get_device_bandwidth(params: DeviceBandwidthInput) -> str:
    """Retrieve current and historical bandwidth utilization for a network device.

    Connects to the specified device via its registered connector and returns
    per-interface bandwidth metrics including current utilization, peak, average,
    and 95th percentile values with trend samples.

    Args:
        params (DeviceBandwidthInput): Device query parameters including:
            - device_id: connector_id or device hostname
            - interfaces: optional list of interface names to filter
            - time_range_hours: history window (1-720 hours)
            - include_errors: include error/drop counters
            - response_format: 'markdown' or 'json'

    Returns:
        str: Per-interface bandwidth metrics with utilization status.
    """
    data = await _collect_device_metrics(
        params.device_id,
        params.interfaces,
        params.time_range_hours,
        params.include_errors,
    )

    if "error" in data:
        return f"❌ {data['error']}"

    if params.response_format == ResponseFormat.JSON:
        return json.dumps(data, indent=2, default=str)

    dev = data["device"]
    lines = [
        f"# Bandwidth Utilization: {dev['name']}",
        f"**Host**: {dev['hostname']} | **Site**: {dev['site']} | **Region**: {dev['region']}",
        f"**Connector Type**: {dev['connector_type']} | **Collected**: {data['collection_time']}",
        f"**Time Window**: {params.time_range_hours}h\n",
        "| Interface | Speed | Avg In | Avg Out | Peak | P95 Util | Status |",
        "|---|---|---|---|---|---|---|",
    ]
    for iface in data["interfaces"]:
        speed_str = mbps_to_str(iface["speed_mbps"])
        avg_in = mbps_to_str(iface["avg_in_mbps"])
        avg_out = mbps_to_str(iface["avg_out_mbps"])
        peak = mbps_to_str(max(iface["peak_in_mbps"], iface["peak_out_mbps"]))
        p95 = f"{iface['p95_util_pct']:.1f}%"
        badge = utilization_badge(iface["peak_util_pct"])
        lines.append(
            f"| {iface['name']} ({iface['description']}) | {speed_str} "
            f"| {avg_in} | {avg_out} | {peak} | {p95} | {badge} |"
        )

    if params.include_errors:
        lines.append("\n### Error Counters\n")
        lines.append("| Interface | In Errors | Out Errors | In Drops | Out Drops |")
        lines.append("|---|---|---|---|---|")
        for iface in data["interfaces"]:
            if "in_errors" in iface:
                lines.append(
                    f"| {iface['name']} | {iface.get('in_errors',0)} "
                    f"| {iface.get('out_errors',0)} | {iface.get('in_drops',0)} "
                    f"| {iface.get('out_drops',0)} |"
                )
    return "\n".join(lines)


@mcp.tool(
    name="bw_get_network_summary",
    annotations={
        "title": "Get Network-Wide Bandwidth Summary",
        "readOnlyHint": True,
        "destructiveHint": False,
        "idempotentHint": True,
        "openWorldHint": True,
    }
)
async def bw_get_network_summary(params: NetworkSummaryInput) -> str:
    """Aggregate bandwidth metrics across a site, region, or the entire network.

    Collects utilization data from all matching connectors and returns a
    rolled-up view showing top busiest links, average utilization, and
    capacity headroom summary by site.

    Args:
        params (NetworkSummaryInput): Scope and filter parameters.
            - scope_type: 'site', 'region', 'device_list', or 'all'
            - identifiers: list of site/region names or device IDs
            - top_n: return top N busiest interfaces (default: 10)
            - response_format: 'markdown' or 'json'

    Returns:
        str: Network-wide bandwidth summary with hotspot identification.
    """
    connector_ids = _filter_by_scope(params.scope_type, params.identifiers)
    if not connector_ids:
        return "No connectors found for the specified scope. Register connectors with `bw_add_connector`."

    all_ifaces = []
    site_stats: Dict[str, Dict] = {}

    for cid in connector_ids:
        data = await _collect_device_metrics(cid, time_range_hours=1)
        if "error" in data:
            continue
        site = data["device"]["site"]
        if site not in site_stats:
            site_stats[site] = {"total_speed_mbps": 0, "total_in_mbps": 0, "total_out_mbps": 0, "iface_count": 0}

        for iface in data["interfaces"]:
            all_ifaces.append({
                "device": data["device"]["name"],
                "connector_id": cid,
                "site": site,
                "region": data["device"]["region"],
                **iface,
            })
            site_stats[site]["total_speed_mbps"] += iface["speed_mbps"]
            site_stats[site]["total_in_mbps"] += iface["avg_in_mbps"]
            site_stats[site]["total_out_mbps"] += iface["avg_out_mbps"]
            site_stats[site]["iface_count"] += 1

    # Sort by peak utilization for top-N
    all_ifaces.sort(key=lambda x: x.get("peak_util_pct", 0), reverse=True)
    top_ifaces = all_ifaces[:params.top_n]

    if params.response_format == ResponseFormat.JSON:
        return json.dumps({
            "connector_count": len(connector_ids),
            "interface_count": len(all_ifaces),
            "site_stats": site_stats,
            "top_interfaces": top_ifaces[:params.top_n],
            "collected_at": ts_to_iso(now_ts()),
        }, indent=2, default=str)

    lines = [
        f"# Network Bandwidth Summary",
        f"**Scope**: {params.scope_type.value} | **Devices**: {len(connector_ids)} | **Interfaces**: {len(all_ifaces)}",
        f"**As of**: {ts_to_iso(now_ts())}\n",
    ]

    # Site breakdown
    lines.append("## Site Capacity Overview\n")
    lines.append("| Site | Interfaces | Total Speed | Avg In | Avg Out | Avg Util% |")
    lines.append("|---|---|---|---|---|---|")
    for site, stats in sorted(site_stats.items()):
        avg_util = (stats["total_in_mbps"] + stats["total_out_mbps"]) / (2 * max(stats["total_speed_mbps"], 1)) * 100
        lines.append(
            f"| {site} | {stats['iface_count']} | {mbps_to_str(stats['total_speed_mbps'])} "
            f"| {mbps_to_str(stats['total_in_mbps'])} | {mbps_to_str(stats['total_out_mbps'])} "
            f"| {avg_util:.1f}% |"
        )

    lines.append(f"\n## Top {params.top_n} Busiest Links\n")
    lines.append("| Device | Interface | Speed | Peak Util | P95 Util | Avg In | Avg Out | Status |")
    lines.append("|---|---|---|---|---|---|---|---|")
    for iface in top_ifaces:
        lines.append(
            f"| {iface['device']} | {iface['name']} ({iface.get('description','')}) "
            f"| {mbps_to_str(iface['speed_mbps'])} | {iface['peak_util_pct']:.1f}% "
            f"| {iface['p95_util_pct']:.1f}% | {mbps_to_str(iface['avg_in_mbps'])} "
            f"| {mbps_to_str(iface['avg_out_mbps'])} | {utilization_badge(iface['peak_util_pct'])} |"
        )

    # Count by status
    critical = sum(1 for i in all_ifaces if i.get("peak_util_pct", 0) >= 85)
    warning = sum(1 for i in all_ifaces if 70 <= i.get("peak_util_pct", 0) < 85)
    healthy = len(all_ifaces) - critical - warning
    lines.append(f"\n---\n**Health Summary**: 🔴 Critical: {critical} | 🟡 Warning: {warning} | 🟢 Healthy: {healthy}")
    return "\n".join(lines)


@mcp.tool(
    name="bw_calculate_requirements",
    annotations={
        "title": "Calculate Bandwidth Requirements",
        "readOnlyHint": True,
        "destructiveHint": False,
        "idempotentHint": True,
        "openWorldHint": True,
    }
)
async def bw_calculate_requirements(params: CalculateBandwidthInput) -> str:
    """Calculate total bandwidth requirements using configurable models.

    The primary calculation tool. Aggregates metrics across all matching
    connectors and applies a selected calculation model (peak, 95th percentile,
    average+headroom, or AIOps forecast) to produce per-link and aggregate
    bandwidth requirement assessments with optional growth projections.

    Calculation models:
        - peak_utilization: Max observed BW + headroom buffer
        - 95th_percentile: P95 of 5-min samples + headroom (recommended)
        - average_plus_headroom: Mean utilization + headroom buffer
        - aiops_forecast: ML-based forward projection (requires AIOps connector)

    Args:
        params (CalculateBandwidthInput): Calculation parameters including
            scope, model, headroom %, growth rate, projection years, SLA profile.

    Returns:
        str: Per-link and aggregate bandwidth requirements with SLA evaluation.
    """
    connector_ids = _filter_by_scope(params.scope_type, params.identifiers)
    if not connector_ids:
        return "No connectors found for specified scope."

    profile = _get_profile(params.sla_profile)
    results = []
    aggregate = {"total_speed_mbps": 0, "total_current_mbps": 0, "total_required_mbps": 0, "total_projected_mbps": 0}

    for cid in connector_ids:
        data = await _collect_device_metrics(cid, time_range_hours=params.time_window_days * 24)
        if "error" in data:
            continue
        dev = data["device"]

        for iface in data["interfaces"]:
            if iface["speed_mbps"] == 0:
                continue
            samples_util = [s["util_pct"] for s in iface["samples"]]
            # Use peak_util and p95 as proxies for longer windows
            samples_util = samples_util + [iface["peak_util_pct"]] * 3 + [iface["p95_util_pct"]] * 10

            calc = _calculate_required_bw(
                samples_util, iface["speed_mbps"],
                params.calculation_model, params.headroom_pct,
                params.growth_rate_pct, params.projection_years,
                params.include_growth_projection
            )
            rag = rag_status(calc["utilization_of_capacity_pct"], profile)
            results.append({
                "device": dev["name"], "site": dev["site"], "region": dev["region"],
                "interface": iface["name"], "description": iface["description"],
                "speed_mbps": iface["speed_mbps"], "rag": rag, **calc,
            })
            aggregate["total_speed_mbps"] += iface["speed_mbps"]
            aggregate["total_current_mbps"] += calc["current_mbps"]
            aggregate["total_required_mbps"] += calc["required_mbps"]
            aggregate["total_projected_mbps"] += calc["projected_mbps"]

    if not results:
        return "No interface data collected. Verify connector configurations."

    if params.response_format == ResponseFormat.JSON:
        return json.dumps({
            "model": params.calculation_model.value,
            "headroom_pct": params.headroom_pct,
            "growth_rate_pct": params.growth_rate_pct if params.include_growth_projection else None,
            "projection_years": params.projection_years,
            "sla_profile": params.sla_profile,
            "aggregate": aggregate,
            "results": results,
        }, indent=2, default=str)

    model_label = params.calculation_model.value.replace("_", " ").title()
    agg_util = aggregate["total_current_mbps"] / max(aggregate["total_speed_mbps"], 1) * 100

    lines = [
        f"# Bandwidth Requirements Analysis",
        f"**Model**: {model_label} | **Headroom**: {params.headroom_pct}% | **SLA Profile**: {params.sla_profile}",
        f"**Growth Rate**: {params.growth_rate_pct}%/yr | **Projection**: {params.projection_years}yr | "
        f"**Links Analyzed**: {len(results)}\n",
        "## Aggregate Summary\n",
        f"| Metric | Value |",
        f"|---|---|",
        f"| Total Network Capacity | {mbps_to_str(aggregate['total_speed_mbps'])} |",
        f"| Current Aggregate Load | {mbps_to_str(aggregate['total_current_mbps'])} ({agg_util:.1f}%) |",
        f"| Required Bandwidth (w/ headroom) | {mbps_to_str(aggregate['total_required_mbps'])} |",
        f"| Projected Bandwidth ({params.projection_years}yr) | {mbps_to_str(aggregate['total_projected_mbps'])} |",
        f"| Overall Status | {utilization_badge(agg_util)} |",
        "",
        "## Per-Link Requirements\n",
        "| Device | Interface | Speed | Current | Required | Projected | Headroom | RAG |",
        "|---|---|---|---|---|---|---|---|",
    ]

    # Sort by utilization descending
    results.sort(key=lambda x: x.get("utilization_of_capacity_pct", 0), reverse=True)
    for r in results:
        rag_icon = "🔴" if r["rag"].startswith("RED") else ("🟡" if r["rag"].startswith("AMBER") else "🟢")
        lines.append(
            f"| {r['device']} | {r['interface']} ({r['description']}) "
            f"| {mbps_to_str(r['speed_mbps'])} | {mbps_to_str(r['current_mbps'])} ({r['utilization_of_capacity_pct']:.1f}%) "
            f"| {mbps_to_str(r['required_mbps'])} | {mbps_to_str(r['projected_mbps'])} "
            f"| {mbps_to_str(r['headroom_mbps'])} ({r['headroom_pct']:.1f}%) | {rag_icon} {r['rag']} |"
        )

    red_count = sum(1 for r in results if r["rag"].startswith("RED"))
    amber_count = sum(1 for r in results if r["rag"].startswith("AMBER"))
    lines.append(f"\n---\n**RAG Summary**: 🔴 {red_count} links at risk | 🟡 {amber_count} links warning | 🟢 {len(results)-red_count-amber_count} links healthy")
    return "\n".join(lines)


@mcp.tool(
    name="bw_compare_historical_trends",
    annotations={
        "title": "Compare Historical Bandwidth Trends",
        "readOnlyHint": True,
        "destructiveHint": False,
        "idempotentHint": True,
        "openWorldHint": True,
    }
)
async def bw_compare_historical_trends(params: HistoricalTrendsInput) -> str:
    """Analyze bandwidth utilization trends over a configurable historical window.

    Computes growth rates, trend direction, and extrapolates when capacity
    will be reached using linear regression on historical samples. Identifies
    devices with the fastest-growing bandwidth consumption.

    Args:
        params (HistoricalTrendsInput): Analysis parameters.
            - device_id: optional specific device to analyze
            - interface_name: optional specific interface
            - time_window_days: historical window length (default: 30 days)
            - response_format: 'markdown' or 'json'

    Returns:
        str: Trend analysis with growth rates, slope, and capacity forecasts.
    """
    if params.device_id:
        connector_ids = [params.device_id] if params.device_id in _connector_registry else []
    else:
        connector_ids = list(_connector_registry.keys())

    if not connector_ids:
        return f"Device '{params.device_id}' not found. Use `bw_list_connectors` to see available devices."

    trend_results = []
    for cid in connector_ids[:15]:  # Cap at 15 for performance
        data = await _collect_device_metrics(cid, time_range_hours=min(params.time_window_days * 24, 720))
        if "error" in data:
            continue
        dev = data["device"]
        for iface in data["interfaces"]:
            if params.interface_name and iface["name"] != params.interface_name:
                continue
            if iface["speed_mbps"] == 0:
                continue
            samples = iface["samples"]
            if len(samples) < 4:
                continue
            # Trend analysis on utilization
            x = list(range(len(samples)))
            y = [s["util_pct"] for s in samples]
            slope, intercept = linear_regression(x, y)
            current_util = y[-1]
            trend_per_day = slope * (86400 / 300)  # convert per-sample slope to per-day

            # Days until critical (85%) if trend continues
            if slope > 0 and current_util < 85:
                samples_to_critical = (85 - current_util) / slope
                days_to_critical = samples_to_critical * 300 / 86400
            else:
                days_to_critical = None

            direction = "📈 Growing" if slope > 0.01 else ("📉 Declining" if slope < -0.01 else "➡️ Stable")

            trend_results.append({
                "device": dev["name"], "site": dev["site"],
                "interface": iface["name"], "description": iface["description"],
                "speed_mbps": iface["speed_mbps"],
                "current_util_pct": current_util,
                "avg_util_pct": iface["avg_util_pct"],
                "trend_direction": direction,
                "slope_pct_per_day": trend_per_day,
                "30d_growth_pct": trend_per_day * 30,
                "days_to_critical": days_to_critical,
                "projected_util_90d": min(100, current_util + trend_per_day * 90),
            })

    if not trend_results:
        return "No trend data available."

    if params.response_format == ResponseFormat.JSON:
