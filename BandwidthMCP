def now_ts() -> float:
    return time.time()

def ts_to_iso(ts: float) -> str:
    return datetime.fromtimestamp(ts, tz=timezone.utc).isoformat()

def mbps_to_str(mbps: float) -> str:
    if mbps >= 1000:
        return f"{mbps/1000:.2f} Gbps"
    elif mbps >= 1:
        return f"{mbps:.2f} Mbps"
    else:
        return f"{mbps*1000:.2f} Kbps"

def utilization_badge(pct: float) -> str:
    if pct >= 95:
        return "🔴 EXHAUSTED"
    elif pct >= 85:
        return "🔴 CRITICAL"
    elif pct >= 70:
        return "🟡 WARNING"
    elif pct >= 50:
        return "🟢 MODERATE"
    else:
        return "🟢 HEALTHY"

def rag_status(pct: float, profile: Dict[str, float]) -> str:
    if pct >= profile.get("exhaustion_pct", 95):
        return "RED"
    elif pct >= profile.get("critical_pct", 85):
        return "AMBER-HIGH"
    elif pct >= profile.get("warning_pct", 70):
        return "AMBER"
    else:
        return "GREEN"

def percentile(data: List[float], pct: float) -> float:
    if not data:
        return 0.0
    sorted_data = sorted(data)
    k = (len(sorted_data) - 1) * pct / 100
    f = math.floor(k)
    c = math.ceil(k)
    if f == c:
        return sorted_data[int(k)]
    return sorted_data[f] * (c - k) + sorted_data[c] * (k - f)

def linear_regression(x: List[float], y: List[float]) -> Tuple[float, float]:
    """Returns (slope, intercept) for least-squares line."""
    n = len(x)
    if n < 2:
        return 0.0, (y[0] if y else 0.0)
    mean_x = sum(x) / n
    mean_y = sum(y) / n
    num = sum((x[i] - mean_x) * (y[i] - mean_y) for i in range(n))
    den = sum((x[i] - mean_x) ** 2 for i in range(n))
    slope = num / den if den != 0 else 0.0
    intercept = mean_y - slope * mean_x
    return slope, intercept

def _get_profile(profile_name: Optional[str]) -> Dict[str, float]:
    return _threshold_profiles.get(profile_name or "default", _threshold_profiles["default"])

def _filter_by_scope(scope_type: ScopeType, identifiers: Optional[List[str]]) -> List[str]:
    """Return list of connector_ids matching the given scope."""
    all_ids = list(_connector_registry.keys())
    if scope_type == ScopeType.ALL or not identifiers:
        return all_ids
    matched = []
    for cid, cfg in _connector_registry.items():
        if scope_type == ScopeType.SITE and cfg.get("site") in identifiers:
            matched.append(cid)
        elif scope_type == ScopeType.REGION and cfg.get("region") in identifiers:
            matched.append(cid)
        elif scope_type == ScopeType.DEVICE_LIST and cid in identifiers:
            matched.append(cid)
    return matched

