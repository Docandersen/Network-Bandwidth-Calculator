@mcp.resource("bw://connectors")
async def resource_connectors() -> str:
    """All registered connectors as a JSON resource."""
    safe = {k: {**v, "password": "***" if "password" in v else None} for k, v in _connector_registry.items()}
    return json.dumps(safe, indent=2)

@mcp.resource("bw://devices/{device_id}")
async def resource_device(device_id: str) -> str:
    """Device info for a specific registered device."""
    if device_id not in _connector_registry:
        return json.dumps({"error": f"Device '{device_id}' not found"})
    data = await _collect_device_metrics(device_id, time_range_hours=1)
    return json.dumps(data, indent=2, default=str)

@mcp.resource("bw://thresholds")
async def resource_thresholds() -> str:
    """All configured SLA threshold profiles."""
    return json.dumps(_threshold_profiles, indent=2)

@mcp.resource("bw://sites")
async def resource_sites() -> str:
    """Distinct sites across all registered connectors."""
    sites = {}
    for cfg in _connector_registry.values():
        site = cfg.get("site", "unknown")
        if site not in sites:
            sites[site] = {"region": cfg.get("region", "global"), "connectors": []}
        sites[site]["connectors"].append(cfg["connector_id"])
    return json.dumps(sites, indent=2)

