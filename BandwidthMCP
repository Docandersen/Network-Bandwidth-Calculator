        f"**Devices analyzed**: {len(set(r['device'] for r in trend_results))} | "
        f"**Interfaces**: {len(trend_results)}\n",
        "## Trend Summary\n",
        "| Device | Interface | Speed | Current Util | Trend | Daily Growth | 90d Forecast | Days→Critical |",
        "|---|---|---|---|---|---|---|---|",
    ]
    for r in trend_results[:20]:  # Show top 20
        days_crit = f"{r['days_to_critical']:.0f}d" if r["days_to_critical"] else "N/A"
        lines.append(
            f"| {r['device']} | {r['interface']} ({r['description']}) "
            f"| {mbps_to_str(r['speed_mbps'])} | {r['current_util_pct']:.1f}% "
            f"| {r['trend_direction']} | {r['slope_pct_per_day']:.2f}%/day "
            f"| {r['projected_util_90d']:.1f}% | {days_crit} |"
        )

    # Links approaching critical within 90 days
    at_risk = [r for r in trend_results if r.get("days_to_critical") and r["days_to_critical"] <= 90]
    if at_risk:
        lines.append(f"\n## ⚠️ Links Approaching Critical Capacity ({len(at_risk)} links within 90 days)\n")
        for r in sorted(at_risk, key=lambda x: x["days_to_critical"]):
            lines.append(f"- **{r['device']}** {r['interface']}: {r['days_to_critical']:.0f} days to 85% utilization")

