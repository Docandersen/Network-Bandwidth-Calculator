    return anomalies

def _calculate_required_bw(
    samples_util_pct: List[float],
    speed_mbps: float,
    model: CalculationModel,
    headroom_pct: float,
    growth_rate_pct: float,
    projection_years: float,
    include_growth: bool,
) -> Dict[str, float]:
    """Core calculation engine. Returns bandwidth requirements in Mbps."""
    if not samples_util_pct or speed_mbps == 0:
        return {"required_mbps": 0, "current_mbps": 0, "headroom_mbps": 0}

    if model == CalculationModel.PEAK_UTILIZATION:
        base_util = max(samples_util_pct)
    elif model == CalculationModel.PERCENTILE_95:
        base_util = percentile(samples_util_pct, 95)
    elif model == CalculationModel.AVERAGE_PLUS_HEADROOM:
        base_util = statistics.mean(samples_util_pct)
    else:  # aiops_forecast - use exponential smoothing of recent trend
        n = len(samples_util_pct)
        if n > 10:
            recent = samples_util_pct[-int(n * 0.3):]
            base_util = statistics.mean(recent) * 1.1  # 10% uplift for AI forecast
        else:
            base_util = statistics.mean(samples_util_pct)

    current_mbps = base_util / 100.0 * speed_mbps
    required_mbps = current_mbps * (1 + headroom_pct / 100)

    if include_growth and projection_years > 0:
        growth_multiplier = (1 + growth_rate_pct / 100) ** projection_years
        projected_mbps = required_mbps * growth_multiplier
    else:
        projected_mbps = required_mbps

    return {
        "base_utilization_pct": base_util,
        "current_mbps": current_mbps,
        "required_mbps": required_mbps,
        "projected_mbps": projected_mbps,
        "headroom_mbps": speed_mbps - current_mbps,
        "headroom_pct": max(0, (speed_mbps - current_mbps) / speed_mbps * 100) if speed_mbps > 0 else 0,
        "utilization_of_capacity_pct": current_mbps / speed_mbps * 100 if speed_mbps > 0 else 0,
    }

