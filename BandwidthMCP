@mcp.tool(
    name="bw_run_audit",
    annotations={
        "title": "Run Full Bandwidth Audit",
        "readOnlyHint": True,
        "destructiveHint": False,
        "idempotentHint": False,
        "openWorldHint": True,
    }
)
async def bw_run_audit(params: BandwidthAuditInput, ctx: Context) -> str:
    """Execute a comprehensive bandwidth audit across all integrated sources.

    Performs a full multi-pass data collection sweep across all matching
    connectors, calculates requirements using the 95th percentile model,
    evaluates SLA compliance, checks for anomalies, and generates a
    prioritized remediation recommendation list.

    Args:
        params (BandwidthAuditInput): Audit scope and output parameters.
            - scope_type / identifiers: which devices to audit
            - include_recommendations: include prioritized upgrade recommendations
            - response_format: 'markdown' or 'json'

    Returns:
        str: Comprehensive audit report with findings and recommendations.
    """
    connector_ids = _filter_by_scope(params.scope_type, params.identifiers)
    await ctx.report_progress(0.1, f"Collecting metrics from {len(connector_ids)} connectors...")

    # 1. Collect all device metrics
    all_metrics = []
    for cid in connector_ids:
        data = await _collect_device_metrics(cid, time_range_hours=24)
        if "error" not in data:
            all_metrics.append(data)

    await ctx.report_progress(0.4, "Running bandwidth calculations...")

    # 2. Calculate requirements for all interfaces
    profile = _get_profile("default")
    audit_findings = []
    total_links = 0
    red_links = 0
    amber_links = 0

    for device_data in all_metrics:
        dev = device_data["device"]
        for iface in device_data["interfaces"]:
            if iface["speed_mbps"] == 0:
                continue
            total_links += 1
            util = iface["peak_util_pct"]
            rag = rag_status(util, profile)
            if rag.startswith("RED"):
                red_links += 1
            elif rag.startswith("AMBER"):
                amber_links += 1

            calc = _calculate_required_bw(
                [iface["p95_util_pct"]], iface["speed_mbps"],
                CalculationModel.PERCENTILE_95, DEFAULT_HEADROOM_PCT,
                DEFAULT_GROWTH_RATE_PCT, 1.0, True
            )
            audit_findings.append({
                "device": dev["name"], "site": dev["site"],
                "interface": iface["name"], "description": iface["description"],
                "speed_mbps": iface["speed_mbps"],
                "peak_util_pct": util, "rag": rag, **calc,
            })

    await ctx.report_progress(0.7, "Collecting anomaly alerts...")

    # 3. Get anomalies
    anomalies = await _collect_aiops_anomalies(connector_ids)
    critical_anomalies = [a for a in anomalies if a["severity"] == "critical"]

    await ctx.report_progress(0.9, "Generating recommendations...")

    # 4. Generate recommendations
    recommendations = []
    if params.include_recommendations:
        red_ifaces = [f for f in audit_findings if f["rag"].startswith("RED")]
        for r in sorted(red_ifaces, key=lambda x: x["peak_util_pct"], reverse=True):
            next_tier = r["speed_mbps"] * 2
            recommendations.append({
                "priority": "HIGH",
                "device": r["device"], "interface": r["interface"],
                "action": f"Upgrade link from {mbps_to_str(r['speed_mbps'])} to {mbps_to_str(next_tier)}",
                "rationale": f"Peak utilization {r['peak_util_pct']:.1f}% exceeds critical threshold",
                "estimated_timeline": "0-30 days",
            })
        amber_ifaces = [f for f in audit_findings if f["rag"].startswith("AMBER")]
        for r in amber_ifaces[:3]:
            recommendations.append({
                "priority": "MEDIUM",
                "device": r["device"], "interface": r["interface"],
                "action": f"Plan capacity upgrade within 90 days for {mbps_to_str(r['speed_mbps'])} link",
                "rationale": f"Peak utilization {r['peak_util_pct']:.1f}% approaching critical threshold",
                "estimated_timeline": "30-90 days",
            })

    await ctx.report_progress(1.0, "Audit complete.")

    if params.response_format == ResponseFormat.JSON:
        return json.dumps({
            "audit_time": ts_to_iso(now_ts()),
            "scope": {"type": params.scope_type.value, "identifiers": params.identifiers},
            "summary": {
                "total_devices": len(all_metrics), "total_links": total_links,
                "red_links": red_links, "amber_links": amber_links,
                "active_anomalies": len(anomalies), "critical_anomalies": len(critical_anomalies),
            },
            "findings": audit_findings,
            "anomalies": anomalies,
            "recommendations": recommendations,
        }, indent=2, default=str)

    lines = [
        f"# Bandwidth Audit Report",
        f"**Generated**: {ts_to_iso(now_ts())} | **Scope**: {params.scope_type.value}",
        f"**MCP Version**: {VERSION}\n",
        "## Executive Summary\n",
        f"| Metric | Value |",
        f"|---|---|",
        f"| Devices Audited | {len(all_metrics)} |",
        f"| Links Evaluated | {total_links} |",
        f"| 🔴 Critical Links | {red_links} |",
        f"| 🟡 Warning Links | {amber_links} |",
        f"| 🟢 Healthy Links | {total_links - red_links - amber_links} |",
        f"| Active AIOps Anomalies | {len(anomalies)} ({len(critical_anomalies)} critical) |",
        "",
        "## Link Health Summary\n",
        "| Device | Interface | Speed | Peak Util | P95 Util | Required BW | RAG |",
        "|---|---|---|---|---|---|---|",
    ]
    for r in sorted(audit_findings, key=lambda x: x["peak_util_pct"], reverse=True)[:20]:
        rag_icon = "🔴" if r["rag"].startswith("RED") else ("🟡" if r["rag"].startswith("AMBER") else "🟢")
        lines.append(
            f"| {r['device']} | {r['interface']} ({r['description']}) "
            f"| {mbps_to_str(r['speed_mbps'])} | {r['peak_util_pct']:.1f}% "
            f"| {r.get('base_utilization_pct', 0):.1f}% | {mbps_to_str(r['required_mbps'])} "
            f"| {rag_icon} {r['rag']} |"
        )

    if recommendations:
        lines.append("\n## Prioritized Recommendations\n")
        for i, rec in enumerate(recommendations, 1):
            icon = "🔴" if rec["priority"] == "HIGH" else "🟡"
            lines.append(f"### {icon} Rec {i} [{rec['priority']}]: {rec['device']} - {rec['interface']}")
            lines.append(f"**Action**: {rec['action']}")
            lines.append(f"**Rationale**: {rec['rationale']}")
            lines.append(f"**Timeline**: {rec['estimated_timeline']}\n")

    return "\n".join(lines)


@mcp.tool(
    name="bw_generate_report",
    annotations={
        "title": "Generate Capacity Planning Report",
        "readOnlyHint": True,
        "destructiveHint": False,
        "idempotentHint": False,
        "openWorldHint": True,
    }
)
async def bw_generate_report(params: CapacityReportInput, ctx: Context) -> str:
    """Generate a comprehensive bandwidth capacity planning report.

    Produces a full capacity planning report including current state analysis,
    trend analysis, bandwidth requirements, growth projections, AIOps insights,
    and prioritized upgrade recommendations. Supports Markdown, JSON, and CSV output.

    Args:
        params (CapacityReportInput): Report configuration including scope,
            calculation model, headroom, growth assumptions, SLA profile,
            and output format.

    Returns:
        str: Formatted capacity planning report ready for stakeholder delivery.
    """
    await ctx.report_progress(0.05, "Initializing capacity report generation...")

    connector_ids = _filter_by_scope(params.scope_type, params.identifiers)
    profile = _get_profile(params.sla_profile)

    await ctx.report_progress(0.2, "Collecting current state metrics...")
    all_device_metrics = []
    for cid in connector_ids:
        data = await _collect_device_metrics(cid, time_range_hours=720)  # 30 days
        if "error" not in data:
            all_device_metrics.append(data)

    await ctx.report_progress(0.5, "Running calculations and projections...")
    all_results = []
    site_rollup: Dict[str, Dict] = {}

    for device_data in all_device_metrics:
        dev = device_data["device"]
        site = dev["site"]
        if site not in site_rollup:
            site_rollup[site] = {
                "total_speed_mbps": 0, "total_required_mbps": 0,
                "total_projected_mbps": 0, "link_count": 0, "red": 0, "amber": 0
            }

        for iface in device_data["interfaces"]:
            if iface["speed_mbps"] == 0:
                continue
            samples_util = [s["util_pct"] for s in iface["samples"]]
            calc = _calculate_required_bw(
                samples_util, iface["speed_mbps"],
                params.calculation_model, params.headroom_pct,
                params.growth_rate_pct, 1.0, params.include_growth_projection
            )
            rag = rag_status(calc["utilization_of_capacity_pct"], profile)
            result = {
                "device": dev["name"], "site": site, "region": dev["region"],
                "interface": iface["name"], "description": iface["description"],
                "speed_mbps": iface["speed_mbps"],
                "rag": rag, **calc,
            }
            all_results.append(result)
            site_rollup[site]["total_speed_mbps"] += iface["speed_mbps"]
            site_rollup[site]["total_required_mbps"] += calc["required_mbps"]
            site_rollup[site]["total_projected_mbps"] += calc["projected_mbps"]
            site_rollup[site]["link_count"] += 1
            if rag.startswith("RED"):
                site_rollup[site]["red"] += 1
            elif rag.startswith("AMBER"):
                site_rollup[site]["amber"] += 1

    await ctx.report_progress(0.75, "Fetching AIOps insights...")
    anomalies = await _collect_aiops_anomalies(connector_ids)

    await ctx.report_progress(0.9, "Assembling final report...")

    if params.report_format == "json":
        return json.dumps({
            "report_metadata": {
                "title": "Bandwidth Capacity Planning Report",
                "generated_at": ts_to_iso(now_ts()),
                "version": VERSION,
                "calculation_model": params.calculation_model.value,
                "headroom_pct": params.headroom_pct,
                "growth_rate_pct": params.growth_rate_pct,
                "sla_profile": params.sla_profile,
            },
            "summary": {
                "total_devices": len(all_device_metrics),
                "total_links": len(all_results),
                "red_links": sum(1 for r in all_results if r["rag"].startswith("RED")),
                "amber_links": sum(1 for r in all_results if r["rag"].startswith("AMBER")),
                "total_capacity_mbps": sum(r["speed_mbps"] for r in all_results),
                "total_required_mbps": sum(r["required_mbps"] for r in all_results),
                "active_anomalies": len(anomalies),
            },
            "site_rollup": site_rollup,
            "per_link_results": all_results,
            "anomalies": anomalies,
        }, indent=2, default=str)

    if params.report_format == "csv":
        lines = ["Device,Site,Region,Interface,Description,Speed (Mbps),Current (Mbps),"
                 "Required (Mbps),Projected (Mbps),Headroom (Mbps),Util %,RAG"]
        for r in all_results:
            lines.append(
                f"{r['device']},{r['site']},{r['region']},{r['interface']},"
                f"{r['description']},{r['speed_mbps']:.1f},{r['current_mbps']:.1f},"
                f"{r['required_mbps']:.1f},{r['projected_mbps']:.1f},"
                f"{r['headroom_mbps']:.1f},{r['utilization_of_capacity_pct']:.1f},{r['rag']}"
            )
        return "\n".join(lines)

    # Markdown report
    red_links = [r for r in all_results if r["rag"].startswith("RED")]
    amber_links = [r for r in all_results if r["rag"].startswith("AMBER")]
    total_cap = sum(r["speed_mbps"] for r in all_results)
    total_req = sum(r["required_mbps"] for r in all_results)
    total_proj = sum(r["projected_mbps"] for r in all_results)
    overall_util = sum(r["current_mbps"] for r in all_results) / max(total_cap, 1) * 100

    lines = [
        "# Bandwidth Capacity Planning Report",
        f"**Generated**: {ts_to_iso(now_ts())} | **Version**: {VERSION}",
        f"**Model**: {params.calculation_model.value.replace('_',' ').title()} | "
        f"**Headroom**: {params.headroom_pct}% | **Growth Rate**: {params.growth_rate_pct}%/yr",
        f"**SLA Profile**: {params.sla_profile} (Warning: {profile['warning_pct']}%, Critical: {profile['critical_pct']}%)\n",
        "---\n",
        "## 1. Executive Summary\n",
        f"The network consists of **{len(all_device_metrics)} devices** across "
        f"**{len(site_rollup)} sites** with a total monitored capacity of "
        f"**{mbps_to_str(total_cap)}**. Current aggregate utilization is "
        f"**{overall_util:.1f}%** of installed capacity.\n",
        f"- **{len(red_links)}** links are at or approaching capacity exhaustion (🔴 RED status)",
        f"- **{len(amber_links)}** links are at warning thresholds (🟡 AMBER status)",
        f"- **{len(all_results) - len(red_links) - len(amber_links)}** links are healthy (🟢 GREEN status)",
        f"- **{len(anomalies)}** active anomalies detected by AIOps platforms\n",
        "**Immediate action required** on the following sites: " +
        (", ".join(set(r["site"] for r in red_links)) or "None") + "\n",
        "---\n",
        "## 2. Site Capacity Summary\n",
        "| Site | Links | Total Capacity | Required BW | Projected (1yr) | Red | Amber | Green |",
        "|---|---|---|---|---|---|---|---|",
    ]
    for site, s in sorted(site_rollup.items()):
        green = s["link_count"] - s["red"] - s["amber"]
        lines.append(
            f"| {site} | {s['link_count']} | {mbps_to_str(s['total_speed_mbps'])} "
            f"| {mbps_to_str(s['total_required_mbps'])} | {mbps_to_str(s['total_projected_mbps'])} "
            f"| 🔴 {s['red']} | 🟡 {s['amber']} | 🟢 {green} |"
        )

    lines += [
        "\n---\n",
        "## 3. Current State — Top 20 Busiest Links\n",
        "| Device | Interface | Speed | Current | Required | Projected | RAG |",
        "|---|---|---|---|---|---|---|",
    ]
    for r in sorted(all_results, key=lambda x: x["utilization_of_capacity_pct"], reverse=True)[:20]:
        rag_icon = "🔴" if r["rag"].startswith("RED") else ("🟡" if r["rag"].startswith("AMBER") else "🟢")
        lines.append(
            f"| {r['device']} | {r['interface']} ({r['description']}) "
            f"| {mbps_to_str(r['speed_mbps'])} | {mbps_to_str(r['current_mbps'])} ({r['utilization_of_capacity_pct']:.1f}%) "
            f"| {mbps_to_str(r['required_mbps'])} | {mbps_to_str(r['projected_mbps'])} | {rag_icon} {r['rag']} |"
        )

    lines += [
        "\n---\n",
        "## 4. AIOps Insights\n",
        f"**Active Anomalies**: {len(anomalies)} | **Critical**: {sum(1 for a in anomalies if a['severity']=='critical')}\n",
    ]
    for a in anomalies[:5]:
        icon = "🔴" if a["severity"] == "critical" else "🟡"
        lines.append(f"- {icon} [{a['source_platform']}] {a['title']} — Device: {a['affected_device']}")

    if len(anomalies) > 5:
        lines.append(f"\n_...and {len(anomalies)-5} more anomalies. Use `bw_get_anomaly_alerts` for full list._")

    lines += [
        "\n---\n",
        "## 5. Bandwidth Requirements Summary\n",
        f"| Metric | Value |",
        f"|---|---|",
        f"| Total Installed Capacity | {mbps_to_str(total_cap)} |",
        f"| Current Aggregate Load | {mbps_to_str(sum(r['current_mbps'] for r in all_results))} ({overall_util:.1f}%) |",
        f"| Required BW (w/ {params.headroom_pct}% headroom) | {mbps_to_str(total_req)} |",
        f"| Projected BW (1yr @ {params.growth_rate_pct}%/yr) | {mbps_to_str(total_proj)} |",
        f"| Capacity Shortfall (current) | {mbps_to_str(max(0, total_req - total_cap))} |",
        f"| Capacity Shortfall (1yr projected) | {mbps_to_str(max(0, total_proj - total_cap))} |",
        "",
        "\n---\n",
        "## 6. Upgrade Recommendations\n",
    ]
    if red_links:
        for r in sorted(red_links, key=lambda x: x["utilization_of_capacity_pct"], reverse=True):
            target = mbps_to_str(r["speed_mbps"] * 2)
            lines.append(
                f"1. 🔴 **[URGENT — 0-30 days]** {r['device']} {r['interface']}: "
                f"Upgrade to {target} — current utilization {r['utilization_of_capacity_pct']:.1f}%"
            )
    if amber_links:
        for r in amber_links[:5]:
            lines.append(
                f"2. 🟡 **[PLAN — 30-90 days]** {r['device']} {r['interface']}: "
                f"Plan capacity review — utilization {r['utilization_of_capacity_pct']:.1f}% at warning threshold"
            )
    if not red_links and not amber_links:
        lines.append("✅ No immediate upgrade actions required. Continue monitoring growth trends.")

    lines += [
        "\n---\n",
        "_Report generated by Bandwidth Calculator MCP v" + VERSION + "_"
    ]

    await ctx.report_progress(1.0, "Report complete.")
    return "\n".join(lines)


