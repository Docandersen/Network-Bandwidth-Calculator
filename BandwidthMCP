def _simulate_interface_samples(
    device_id: str,
    iface: str,
    speed_mbps: float,
    hours: int,
    base_util_pct: float = 45.0
) -> List[Dict[str, Any]]:
    """Generate realistic simulated bandwidth samples for a device interface."""
    import random
    random.seed(hash(f"{device_id}:{iface}") % (2**32))
    samples = []
    now = now_ts()
    interval = 300  # 5-minute samples
    count = int(hours * 3600 / interval)
    # Business hours pattern: higher during 08:00-18:00
    for i in range(count):
        ts = now - (count - i) * interval
        hour_of_day = (datetime.fromtimestamp(ts).hour)
        # Business hours multiplier
        if 8 <= hour_of_day <= 18:
            mult = 1.0 + 0.5 * math.sin(math.pi * (hour_of_day - 8) / 10)
        else:
            mult = 0.3 + 0.1 * random.random()
        noise = 1.0 + (random.random() - 0.5) * 0.2
        util_pct = min(99.0, base_util_pct * mult * noise)
        bps = util_pct / 100.0 * speed_mbps * 1_000_000
        samples.append({
            "timestamp": ts,
            "timestamp_iso": ts_to_iso(ts),
            "in_bps": bps * (0.6 + random.random() * 0.2),
            "out_bps": bps * (0.4 + random.random() * 0.2),
            "util_pct": util_pct,
        })
    return samples

def _get_device_interfaces(connector_id: str) -> List[Dict[str, Any]]:
    """Return simulated interface list for a connector/device."""
    cfg = _connector_registry.get(connector_id, {})
    ctype = cfg.get("connector_type", "snmp")
    host = cfg.get("host", connector_id)

    # Generate deterministic interface set per device type
    import random
    random.seed(hash(host) % (2**32))

    interfaces = []
    # WAN/uplink interfaces
    for i in range(2):
        speed = random.choice([100, 1000, 10000])
        base_util = random.uniform(30, 75)
        interfaces.append({
            "name": f"GigabitEthernet0/{i}",
            "description": f"WAN-UPLINK-{i+1}" if i == 0 else "BACKUP-WAN",
            "speed_mbps": speed,
            "base_util_pct": base_util,
            "type": "wan",
        })
    # LAN/distribution interfaces
    for i in range(4):
        speed = random.choice([1000, 10000])
        base_util = random.uniform(10, 55)
        interfaces.append({
            "name": f"TenGigabitEthernet1/{i}",
            "description": f"ACCESS-DIST-{i+1}",
            "speed_mbps": speed,
            "base_util_pct": base_util,
            "type": "lan",
        })
    # Management
    interfaces.append({
        "name": "Loopback0",
        "description": "MGMT-LOOPBACK",
        "speed_mbps": 0,
        "base_util_pct": 0,
        "type": "loopback",
    })
    return interfaces

async def _collect_device_metrics(
    connector_id: str,
    interfaces: Optional[List[str]] = None,
    time_range_hours: int = 1,
    include_errors: bool = False,
) -> Dict[str, Any]:
    """Collect (or simulate) bandwidth metrics for a device connector."""
    cfg = _connector_registry.get(connector_id)
    if not cfg:
        return {"error": f"Connector '{connector_id}' not found. Register it first with bw_add_connector."}

    if not cfg.get("enabled", True):
        return {"error": f"Connector '{connector_id}' is disabled."}

    all_ifaces = _get_device_interfaces(connector_id)
    if interfaces:
        all_ifaces = [i for i in all_ifaces if i["name"] in interfaces]

    iface_metrics = []
    for iface in all_ifaces:
        if iface["speed_mbps"] == 0:
            continue
        samples = _simulate_interface_samples(
            connector_id, iface["name"],
            iface["speed_mbps"], time_range_hours,
            iface["base_util_pct"]
        )
        in_vals = [s["in_bps"] for s in samples]
        out_vals = [s["out_bps"] for s in samples]
        util_vals = [s["util_pct"] for s in samples]

        metric = {
            "name": iface["name"],
            "description": iface["description"],
            "type": iface["type"],
            "speed_mbps": iface["speed_mbps"],
            "current_in_bps": in_vals[-1] if in_vals else 0,
            "current_out_bps": out_vals[-1] if out_vals else 0,
            "current_util_pct": util_vals[-1] if util_vals else 0,
            "avg_in_mbps": statistics.mean(in_vals) / 1_000_000 if in_vals else 0,
            "avg_out_mbps": statistics.mean(out_vals) / 1_000_000 if out_vals else 0,
            "peak_in_mbps": max(in_vals) / 1_000_000 if in_vals else 0,
            "peak_out_mbps": max(out_vals) / 1_000_000 if out_vals else 0,
            "avg_util_pct": statistics.mean(util_vals) if util_vals else 0,
            "peak_util_pct": max(util_vals) if util_vals else 0,
            "p95_util_pct": percentile(util_vals, 95),
            "samples": samples[-12:],  # last hour of 5-min samples
        }
        if include_errors:
            import random
            random.seed(hash(f"{connector_id}:{iface['name']}:err") % (2**32))
            metric["in_errors"] = random.randint(0, 50)
            metric["out_errors"] = random.randint(0, 20)
            metric["in_drops"] = random.randint(0, 100)
            metric["out_drops"] = random.randint(0, 30)
        iface_metrics.append(metric)

    return {
        "connector_id": connector_id,
        "device": {
            "id": connector_id,
            "hostname": cfg.get("host", connector_id),
            "site": cfg.get("site", "unknown"),
            "region": cfg.get("region", "global"),
            "connector_type": cfg.get("connector_type", "snmp"),
            "name": cfg.get("name", connector_id),
        },
        "interfaces": iface_metrics,
        "collection_time": ts_to_iso(now_ts()),
        "time_range_hours": time_range_hours,
    }

